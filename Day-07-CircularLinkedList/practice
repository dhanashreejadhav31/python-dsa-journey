class Node:
    def __init__(self,value = None):
        self.data = value
        self.next = None
        self.prev = None

class CircleLL:
    def __init__(self):
        self.head = None        
    def insertAtEnd(self,value):
        temp = Node(value)
        if(self.head == None):
            self.head = temp
            temp.next = temp
            temp.prev = temp
            return
        t = self.head
        while(t.next != self.head):
            t = t.next
        t.next = temp
        temp.prev = t
        self.head.prev = temp   
        temp.next = self.head
    def printLL(self):
        t = self.head
        while(t.next != self.head):
            print(t.data , end = "<-->")
            t = t.next
        print(t.data)     
    def insertAtBeg(self,value):
        temp = Node(value)
        if (self.head == None):
            self.head = temp
            return
        t = self.head
        while(t.next != self.head):
            t = t.next
        t.next = temp
        temp.prev = t
        self.head.prev = temp
        temp.next = self.head
        self.head = temp   
    def insertAtMid(self,value,x):
        temp = Node(value)
        t = self.head
        while(t.next != self.head):
            if(t.data == x):
                break
            else:
                t = t.next
        temp.next = t.next
        t.next.prev = temp
        t.next = temp 
        temp.prev = t      
    def deleteNode(self, value):
        if self.head is None:
            print("List is Empty.")
            return
        temp = self.head
        if temp.next == self.head and temp.data == value:
            self.head = None
            return
        if temp.data == value:
            last = self.head.prev
            self.head = temp.next
            self.head.prev = last
            last.next = self.head
            return
        while temp.next != self.head:
            if temp.data == value:
                temp.prev.next = temp.next
                temp.next.prev = temp.prev
                return
            temp = temp.next
        if temp.data == value:
            temp.prev.next = self.head
            self.head.prev = temp.prev
            return

        print("Value not found") 


